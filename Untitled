<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kinyl — AI Chief of Staff for Small Business</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAF8F3;
    --cream-dark: #F2EFE6;
    --parchment: #EDE8DC;
    --ink: #1A1814;
    --ink-soft: #3D3A34;
    --ink-muted: #7A7567;
    --accent: #C4773B;
    --accent-light: #E8C4A0;
    --accent-pale: #F7EDE0;
    --teal: #2E6B6B;
    --teal-light: #D4EAEA;
    --red-soft: #C45050;
    --green-soft: #4A7A5A;
    --green-pale: #D8EBE0;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'DM Sans', sans-serif;
    --mono: 'DM Mono', monospace;
    --shadow-sm: 0 1px 3px rgba(26,24,20,0.06), 0 1px 2px rgba(26,24,20,0.04);
    --shadow-md: 0 4px 16px rgba(26,24,20,0.08), 0 2px 6px rgba(26,24,20,0.05);
    --shadow-lg: 0 12px 40px rgba(26,24,20,0.12), 0 4px 12px rgba(26,24,20,0.06);
    --radius: 12px;
    --radius-sm: 6px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px;
  }

  /* ── HEADER ── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    border-bottom: 1px solid var(--parchment);
    background: var(--cream);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-mark {
    width: 32px; height: 32px;
    background: var(--ink);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }

  .logo-mark svg { width: 18px; height: 18px; }

  .logo-name {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.3px;
    color: var(--ink);
  }

  .logo-name span { color: var(--accent); font-style: italic; }

  nav { display: flex; gap: 28px; align-items: center; }

  nav a {
    font-size: 13.5px;
    font-weight: 400;
    color: var(--ink-muted);
    text-decoration: none;
    letter-spacing: 0.2px;
    transition: color 0.2s;
  }

  nav a:hover { color: var(--ink); }

  .btn-primary {
    background: var(--ink);
    color: var(--cream);
    padding: 9px 20px;
    border-radius: var(--radius-sm);
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.2px;
    transition: background 0.2s, transform 0.15s;
    cursor: pointer;
    border: none;
    font-family: var(--sans);
  }

  .btn-primary:hover { background: var(--ink-soft); transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    padding: 80px 40px 60px;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--accent-pale);
    color: var(--accent);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 20px;
  }

  .hero-eyebrow::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: 52px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1.5px;
    color: var(--ink);
    margin-bottom: 22px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-sub {
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 36px;
    font-weight: 300;
  }

  .hero-actions { display: flex; gap: 14px; align-items: center; }

  .btn-outline {
    border: 1.5px solid var(--parchment);
    color: var(--ink-soft);
    background: transparent;
    padding: 9px 20px;
    border-radius: var(--radius-sm);
    font-size: 13.5px;
    font-weight: 400;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    cursor: pointer;
    font-family: var(--sans);
  }

  .btn-outline:hover { border-color: var(--ink-muted); color: var(--ink); }

  .hero-trust {
    margin-top: 40px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12.5px;
    color: var(--ink-muted);
  }

  .trust-avatars { display: flex; }

  .trust-avatars span {
    width: 28px; height: 28px;
    border-radius: 50%;
    border: 2px solid var(--cream);
    margin-left: -8px;
    font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 500;
  }

  .trust-avatars span:first-child { margin-left: 0; }

  /* ── LIVE DASHBOARD (right side of hero) ── */
  .dashboard-preview {
    background: #fff;
    border: 1px solid var(--parchment);
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    animation: floatCard 6s ease-in-out infinite;
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-6px); }
  }

  .dash-topbar {
    background: var(--cream-dark);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--parchment);
  }

  .dash-dots { display: flex; gap: 6px; }
  .dash-dots span { width: 10px; height: 10px; border-radius: 50%; }
  .dash-dots span:nth-child(1) { background: #FFB3B3; }
  .dash-dots span:nth-child(2) { background: #FFD9A0; }
  .dash-dots span:nth-child(3) { background: #B3DDB3; }

  .dash-title-bar {
    font-size: 12px;
    color: var(--ink-muted);
    font-family: var(--mono);
  }

  .dash-body { padding: 18px; }

  .dash-greeting {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 14px;
  }

  .dash-greeting span { color: var(--accent); font-style: italic; }

  /* Alert cards */
  .alert-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }

  .alert-card {
    border-radius: 8px;
    padding: 10px 14px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 12.5px;
    animation: slideIn 0.4s ease forwards;
    opacity: 0;
  }

  .alert-card:nth-child(1) { animation-delay: 0.1s; }
  .alert-card:nth-child(2) { animation-delay: 0.3s; }
  .alert-card:nth-child(3) { animation-delay: 0.5s; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .alert-card.warn { background: #FFF7ED; border: 1px solid #FFD9A0; }
  .alert-card.ok { background: var(--green-pale); border: 1px solid #B3D9C0; }
  .alert-card.info { background: var(--teal-light); border: 1px solid #A0CCCC; }

  .alert-icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }

  .alert-content .alert-title {
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 2px;
    line-height: 1.3;
  }

  .alert-content .alert-body {
    color: var(--ink-muted);
    font-size: 11.5px;
    line-height: 1.4;
  }

  /* Stats row */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 14px;
  }

  .stat-box {
    background: var(--cream);
    border: 1px solid var(--parchment);
    border-radius: 8px;
    padding: 10px 12px;
    text-align: center;
  }

  .stat-val {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.1;
  }

  .stat-val.green { color: var(--green-soft); }
  .stat-val.orange { color: var(--accent); }

  .stat-label {
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.3px;
    margin-top: 3px;
  }

  /* Actions pending */
  .actions-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 8px;
  }

  .action-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 6px;
    margin-bottom: 5px;
    cursor: pointer;
    transition: background 0.15s;
    font-size: 12.5px;
  }

  .action-item:hover { background: var(--cream-dark); }

  .action-chip {
    font-size: 10.5px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .action-chip.approve { background: var(--green-pale); color: var(--green-soft); }
  .action-chip.review { background: var(--accent-pale); color: var(--accent); }

  .action-text { color: var(--ink-soft); flex: 1; line-height: 1.3; }

  .action-arrow { color: var(--ink-muted); font-size: 11px; }

  /* ── SECTION COMMON ── */
  section { padding: 80px 40px; }

  .section-inner { max-width: 1100px; margin: 0 auto; }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--serif);
    font-size: 38px;
    font-weight: 500;
    letter-spacing: -1px;
    line-height: 1.18;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .section-title em { font-style: italic; color: var(--accent); }

  .section-body {
    font-size: 15.5px;
    color: var(--ink-soft);
    line-height: 1.75;
    max-width: 560px;
    font-weight: 300;
  }

  /* ── FEATURES ── */
  .features-section { background: var(--cream-dark); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 52px;
    border: 2px solid var(--parchment);
    border-radius: 16px;
    overflow: hidden;
  }

  .feature-card {
    background: #fff;
    padding: 32px 28px;
    transition: background 0.2s;
    position: relative;
  }

  .feature-card:hover { background: var(--cream); }

  .feature-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 28px; right: 28px;
    height: 1px;
    background: var(--parchment);
  }

  .feature-card:nth-child(n+4)::after { display: none; }

  .feature-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: var(--accent-pale);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    margin-bottom: 16px;
  }

  .feature-title {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
    letter-spacing: -0.2px;
  }

  .feature-desc {
    font-size: 13.5px;
    color: var(--ink-muted);
    line-height: 1.65;
  }

  /* ── HOW IT WORKS ── */
  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    margin-top: 52px;
  }

  .steps { display: flex; flex-direction: column; gap: 0; }

  .step {
    display: flex;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--parchment);
    cursor: pointer;
    transition: padding-left 0.2s;
  }

  .step:last-child { border-bottom: none; }
  .step:hover { padding-left: 6px; }

  .step-num {
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 400;
    color: var(--accent-light);
    width: 40px;
    flex-shrink: 0;
    line-height: 1;
    padding-top: 2px;
  }

  .step-content {}

  .step-title {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .step-desc {
    font-size: 13.5px;
    color: var(--ink-muted);
    line-height: 1.6;
  }

  /* Timeline visual */
  .timeline-card {
    background: #fff;
    border: 1px solid var(--parchment);
    border-radius: 16px;
    padding: 24px;
    box-shadow: var(--shadow-md);
  }

  .timeline-header {
    font-family: var(--serif);
    font-size: 14px;
    color: var(--ink-muted);
    margin-bottom: 20px;
    font-style: italic;
  }

  .tl-item {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
    align-items: flex-start;
  }

  .tl-time {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-muted);
    width: 52px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .tl-dot-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .tl-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    border: 2px solid var(--parchment);
    background: #fff;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .tl-dot.active { background: var(--accent); border-color: var(--accent); }
  .tl-dot.done { background: var(--green-soft); border-color: var(--green-soft); }

  .tl-line {
    width: 1px;
    flex: 1;
    background: var(--parchment);
    margin-top: 2px;
    min-height: 24px;
  }

  .tl-content {}

  .tl-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .tl-sub { font-size: 12px; color: var(--ink-muted); }

  .tl-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 999px;
    margin-top: 4px;
  }

  .tl-badge.saved { background: var(--green-pale); color: var(--green-soft); }
  .tl-badge.sent { background: var(--teal-light); color: var(--teal); }
  .tl-badge.booked { background: var(--accent-pale); color: var(--accent); }

  /* ── PRICING ── */
  .pricing-section { background: var(--cream-dark); }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 52px;
  }

  .pricing-card {
    background: #fff;
    border: 1.5px solid var(--parchment);
    border-radius: 16px;
    padding: 32px 28px;
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
  }

  .pricing-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }

  .pricing-card.featured {
    border-color: var(--ink);
    box-shadow: var(--shadow-lg);
  }

  .pricing-badge {
    position: absolute;
    top: -12px; left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--cream);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.5px;
    padding: 3px 14px;
    border-radius: 999px;
  }

  .pricing-tier {
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 12px;
  }

  .pricing-price {
    font-family: var(--serif);
    font-size: 42px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 4px;
  }

  .pricing-price span { font-size: 20px; font-weight: 400; color: var(--ink-muted); }

  .pricing-cycle {
    font-size: 12.5px;
    color: var(--ink-muted);
    margin-bottom: 24px;
  }

  .pricing-features { list-style: none; margin-bottom: 28px; }

  .pricing-features li {
    font-size: 13.5px;
    color: var(--ink-soft);
    padding: 6px 0;
    border-bottom: 1px solid var(--cream-dark);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .pricing-features li::before {
    content: '✓';
    color: var(--green-soft);
    font-weight: 600;
    font-size: 12px;
    flex-shrink: 0;
  }

  .btn-tier {
    width: 100%;
    padding: 11px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--sans);
    text-align: center;
    text-decoration: none;
    display: block;
    border: none;
  }

  .btn-tier-outline {
    background: transparent;
    border: 1.5px solid var(--parchment);
    color: var(--ink);
  }

  .btn-tier-outline:hover { border-color: var(--ink); }

  .btn-tier-solid {
    background: var(--ink);
    color: var(--cream);
  }

  .btn-tier-solid:hover { background: var(--ink-soft); }

  /* ── TESTIMONIALS ── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 52px;
  }

  .testimonial-card {
    background: #fff;
    border: 1px solid var(--parchment);
    border-radius: 14px;
    padding: 28px;
    transition: box-shadow 0.2s;
  }

  .testimonial-card:hover { box-shadow: var(--shadow-md); }

  .t-quote {
    font-family: var(--serif);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin-bottom: 20px;
    font-style: italic;
  }

  .t-quote::before { content: '"'; color: var(--accent-light); font-size: 28px; line-height: 0; vertical-align: -8px; margin-right: 2px; }
  .t-quote::after { content: '"'; color: var(--accent-light); font-size: 28px; line-height: 0; vertical-align: -8px; margin-left: 2px; }

  .t-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .t-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    font-size: 14px;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .t-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }

  .t-biz {
    font-size: 11.5px;
    color: var(--ink-muted);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    color: var(--cream);
    padding: 60px 40px 32px;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-brand .logo-name { color: var(--cream); }
  .footer-brand .logo-mark { background: var(--cream); }
  .footer-brand .logo-mark svg path { fill: var(--ink); }

  .footer-tagline {
    font-size: 13px;
    color: rgba(250,248,243,0.5);
    margin-top: 14px;
    line-height: 1.7;
    max-width: 240px;
  }

  .footer-col-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: rgba(250,248,243,0.4);
    margin-bottom: 16px;
  }

  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .footer-links a {
    font-size: 13.5px;
    color: rgba(250,248,243,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--cream); }

  .footer-bottom {
